generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model user {
  id                       Int                        @id @default(autoincrement())
  name                     String
  email                    String?                    @unique
  is_active                Boolean?                   @default(true)
  partner                  Boolean?                   @default(false)
  is_user                  Boolean?                   @default(false)
  password                 String?
  member_id                String?
  position_id              Int?
  department_id            Int?
  created_at               DateTime                   @default(now())
  updated_at               DateTime?
  access_level_id          Int?
  membership_type          membership_type?
  parent_id                Int?
  status                   status_type?
  is_sync                  Boolean?                   @default(false)
  sync_id                  Int?
  mode                     classFormat?
  spouse_id                Int?                       @unique
  appointments             appointment[]
  asset_history            asset_history[]
  assignment_submission    assignment_submission[]
  timeSlots                availability[]
  certificate              certificate[]
  course                   course[]
  department_head          department[]
  department_positions     department_positions[]
  enrollments              enrollment[]
  event_attendance         event_attendance[]
  event_attendance_summary event_attendance_summary[]
  event_registers          event_registers[]
  family_of_links          family_relation[]          @relation("FamilyUser")
  family_links             family_relation[]          @relation("UserFamily")
  followUps                follow_up[]
  life_center_member       life_center_member[]
  notes                    note[]
  orders                   orders[]
  prayerRequests           prayer_request[]
  received_notifications   in_app_notification[]       @relation("notification_recipient")
  acted_notifications      in_app_notification[]       @relation("notification_actor")
  notification_preferences notification_preference[]
  push_subscriptions       notification_push_subscription[]
  push_delivery_jobs       notification_push_delivery_job[] @relation("notification_push_delivery_user")
  sms_delivery_jobs        notification_sms_delivery_job[]  @relation("notification_sms_delivery_user")
  system_failure_notification_settings system_notification_settings[] @relation("system_failure_notification_recipient")
  system_failure_notification_settings_updates system_notification_settings[] @relation("system_failure_notification_updated_by")
  attendance_timing_settings_updates attendance_timing_settings[] @relation("attendance_timing_settings_updated_by")
  matched_biometric_punches event_biometric_punch[] @relation("event_biometric_punch_matched_user")
  imported_biometric_punches event_biometric_punch[] @relation("event_biometric_punch_imported_by_user")
  created_biometric_import_jobs event_biometric_import_job[] @relation("event_biometric_import_job_created_by_user")
  event_reports_created    event_reports[]                 @relation("event_report_created_by")
  event_reports_updated    event_reports[]                 @relation("event_report_updated_by")
  event_reports_final_acted event_reports[]                @relation("event_report_final_acted_by")
  event_report_department_approvals event_report_department_approvals[] @relation("event_report_department_approved_by")
  event_report_attendance_approvals event_report_attendance_approval[] @relation("event_report_attendance_approved_by")
  event_report_finance_updates event_report_finance[]      @relation("event_report_finance_updated_by")
  event_report_finance_approvals event_report_finance_approvals[] @relation("event_report_finance_approved_by")
  event_report_finance_role_owner event_report_finance_approvals[] @relation("event_report_finance_role_owner")
  event_report_final_approvals event_report_final_approval_instances[] @relation("event_report_final_acted_by")
  event_report_final_assigned event_report_final_approval_instances[] @relation("event_report_final_assigned_to")
  event_report_viewership   event_report_viewers[]
  event_report_notification_events_actor event_report_notification_events[] @relation("event_report_notification_actor")
  request                  request[]
  hod_user                 request_approvals[]        @relation("hod_user")
  ps_user                  request_approvals[]        @relation("ps_user")
  user_request_comments    request_comments[]
  soul_won                 soul_won[]                 @relation("user_soul_winner")
  soul_won_membership      soul_won?                  @relation("soul_won_member")
  access                   access_level?              @relation(fields: [access_level_id], references: [id])
  parent                   user?                      @relation("UserParent", fields: [parent_id], references: [id])
  children                 user[]                     @relation("UserParent")
  position                 position?                  @relation(fields: [position_id], references: [id])
  spouse                   user?                      @relation("SpouseRelation", fields: [spouse_id], references: [id])
  spouse_of                user?                      @relation("SpouseRelation")
  department               user_departments?
  user_info                user_info?

  @@index([access_level_id], map: "user_access_level_id_fkey")
  @@index([position_id], map: "user_position_id_fkey")
  @@index([parent_id], map: "user_parent_id_fkey")
  @@index([department_id], map: "user_department_id_idx")
  @@index([membership_type], map: "user_membership_type_idx")
  @@index([is_user], map: "user_is_user_idx")
  @@index([is_active], map: "user_is_active_idx")
  @@index([name], map: "user_name_idx")
}

model system_notification_settings {
  id                              Int      @id
  system_failure_recipient_user_id Int?
  updated_by_user_id              Int?
  created_at                      DateTime @default(now())
  updated_at                      DateTime @updatedAt
  system_failure_recipient        user?    @relation("system_failure_notification_recipient", fields: [system_failure_recipient_user_id], references: [id], map: "sys_notif_settings_recipient_fk")
  updated_by                      user?    @relation("system_failure_notification_updated_by", fields: [updated_by_user_id], references: [id], map: "sys_notif_settings_updated_by_fk")

  @@index([system_failure_recipient_user_id], map: "system_notification_settings_recipient_idx")
  @@index([updated_by_user_id], map: "system_notification_settings_updated_by_idx")
}

model attendance_timing_settings {
  id                Int                    @id
  early_value       Int                    @default(15)
  early_unit        attendance_timing_unit @default(MINUTES)
  on_time_value     Int                    @default(15)
  on_time_unit      attendance_timing_unit @default(MINUTES)
  late_value        Int                    @default(15)
  late_unit         attendance_timing_unit @default(MINUTES)
  updated_by_user_id Int?
  created_at        DateTime               @default(now())
  updated_at        DateTime               @updatedAt
  updated_by        user?                  @relation("attendance_timing_settings_updated_by", fields: [updated_by_user_id], references: [id], map: "attendance_timing_settings_updated_by_fk")

  @@index([updated_by_user_id], map: "attendance_timing_settings_updated_by_idx")
}

model user_info {
  id                   Int                     @id @default(autoincrement())
  user_id              Int                     @unique
  title                String?
  date_of_birth        DateTime?
  gender               String
  primary_number       String?
  other_number         String?
  email                String?
  address              String?
  country              String?
  city                 String?
  state_region         String?
  occupation           String?
  company              String?
  member_since         DateTime?
  photo                String?
  emergency_contact_id Int?
  first_name           String?
  last_name            String?
  marital_status       marital_status?
  nationality          String?
  other_name           String?
  work_info_id         Int?
  country_code         String?
  payment_info_token   String?                 @unique
  emergency_contact    user_emergency_contact? @relation(fields: [emergency_contact_id], references: [id])
  user                 user                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  work_info            user_work_info?         @relation(fields: [work_info_id], references: [id])

  @@index([emergency_contact_id], map: "user_info_emergency_contact_id_fkey")
  @@index([work_info_id], map: "user_info_work_info_id_fkey")
}

model family_relation {
  id        Int    @id @default(autoincrement())
  user_id   Int
  family_id Int
  relation  family_relation_type
  family    user   @relation("FamilyUser", fields: [family_id], references: [id])
  user      user   @relation("UserFamily", fields: [user_id], references: [id])

  @@unique([user_id, family_id])
  @@index([family_id], map: "family_relation_family_id_fkey")
}

model user_work_info {
  id                  Int         @id @default(autoincrement())
  name_of_institution String
  industry            String
  position            String
  employment_status   String?
  school_name         String?
  user_info           user_info[]
}

model user_emergency_contact {
  id           Int         @id @default(autoincrement())
  name         String
  relation     String
  phone_number String
  country_code String?
  user_info    user_info[]
}

model department {
  id                   Int                    @id @default(autoincrement())
  name                 String
  department_head      Int?
  description          String?
  created_by           Int
  created_at           DateTime               @default(now())
  updated_by           Int?
  updated_at           DateTime?
  is_sync              Boolean?               @default(false)
  sync_id              Int?
  assets               assets[]
  department_head_info user?                  @relation(fields: [department_head], references: [id])
  department_positions department_positions[]
  position             position[]
  request              request[]
  event_report_department_approvals event_report_department_approvals[]
  user_departments     user_departments[]

  @@index([department_head], map: "department_department_head_fkey")
}

model user_departments {
  id              Int         @id @default(autoincrement())
  user_id         Int         @unique
  department_id   Int?
  department_info department? @relation(fields: [department_id], references: [id])
  user            user        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([department_id], map: "user_departments_department_id_fkey")
}

model position {
  id                   Int                    @id @default(autoincrement())
  name                 String
  department_id        Int?
  description          String?
  created_by           Int
  created_at           DateTime               @default(now())
  updated_by           Int?
  updated_at           DateTime?
  is_sync              Boolean?               @default(false)
  sync_id              Int?
  department_positions department_positions[]
  department           department?            @relation(fields: [department_id], references: [id])
  user                 user[]

  @@index([department_id], map: "position_department_id_fkey")
}

model access_level {
  id             Int       @id @default(autoincrement())
  name           String    @unique
  description    String?
  permissions    String?   @db.LongText
  created_by     Int?
  updated_by     Int?
  deleted_at     DateTime?
  deleted        Boolean   @default(false)
  created_at     DateTime? @default(now())
  updated_at     DateTime?
  users_assigned user[]
}

model assets {
  id                  Int           @id @default(autoincrement())
  name                String
  date_assigned       DateTime?
  date_purchased      DateTime?
  price               Float?
  description         String?
  updated_at          DateTime?
  supplier            String?
  status              asset_status?
  photo               String?
  created_by          Int?
  updated_by          Int?
  created_at          DateTime      @default(now())
  department_assigned Int?
  asset_id            String?
  assigned_to         department?   @relation(fields: [department_assigned], references: [id])

  @@index([department_assigned], map: "assets_department_assigned_fkey")
}

model asset_history {
  id            Int          @id @default(autoincrement())
  title         String
  description   String?
  status_update asset_status
  update_date   DateTime
  userId        Int?
  related_user  user?        @relation(fields: [userId], references: [id])

  @@index([userId], map: "asset_history_userId_fkey")
}

model event_act {
  id                Int           @id @default(autoincrement())
  event_name        String?       @default("event_name")
  event_status      event_status?
  event_type        event_type?
  event_description String?       @default("event_description")
  event_mgt         event_mgt[]
}

model event_mgt {
  id                        Int                         @id @default(autoincrement())
  start_time                String?
  end_time                  String?
  location                  String?
  description               String?
  poster                    String?
  qr_code                   String?
  public_registration_token String                      @default(uuid()) @unique
  created_by                Int
  created_at                DateTime                    @default(now())
  updated_by                Int?
  updated_at                DateTime?
  end_date                  DateTime?
  start_date                DateTime?
  recurrence_end_date       DateTime?
  recurrence_series_id      String?
  timezone                  String?                     @default("UTC")
  event_status              event_status?
  event_type                event_type?
  requires_registration     Boolean                     @default(false)
  registration_end_date     DateTime?
  registration_capacity     Int?
  registration_audience     event_registration_audience @default(MEMBERS_AND_NON_MEMBERS)
  event_name_id             Int
  event_attendance          event_attendance[]
  attendance_summaries      event_attendance_summary[]
  biometric_punches         event_biometric_punch[]
  biometric_import_jobs     event_biometric_import_job[]
  event                     event_act                   @relation(fields: [event_name_id], references: [id])
  event_registers           event_registers[]
  event_reminders           event_reminder[]
  markets                   markets[]
  request                   request[]
  event_reports             event_reports[]
  visit                     visit[]

  @@index([event_name_id], map: "event_mgt_event_name_id_fkey")
  @@index([start_date], map: "event_mgt_start_date_idx")
  @@index([event_type, event_status, start_date], map: "event_mgt_type_status_start_date_idx")
  @@index([recurrence_series_id], map: "event_mgt_recurrence_series_id_idx")
}

model event_reminder {
  id             Int             @id @default(autoincrement())
  event_id       Int
  remind_at      DateTime
  offset_minutes Int
  method         String          @default("in_app")
  status         reminder_status @default(PENDING)
  created_at     DateTime        @default(now())
  event          event_mgt       @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([remind_at, status], map: "event_reminder_remind_at_status_idx")
  @@index([event_id], map: "event_reminder_event_id_idx")
}

model event_attendance_summary {
  id              Int              @id @default(autoincrement())
  event_mgt_id    Int
  date            DateTime
  group           attendance_group @default(BOTH)
  adultMale       Int              @default(0)
  adultFemale     Int              @default(0)
  childrenMale    Int              @default(0)
  childrenFemale  Int              @default(0)
  recordedBy      Int
  recordedByName  String
  created_at      DateTime         @default(now())
  updated_at      DateTime?
  newMembers      Int              @default(0)
  visitingPastors Int              @default(0)
  visitors        Int              @default(0)
  youthFemale     Int              @default(0)
  youthMale       Int              @default(0)
  event           event_mgt        @relation(fields: [event_mgt_id], references: [id])
  recordedByUser  user             @relation(fields: [recordedBy], references: [id])

  @@unique([event_mgt_id, date])
  @@index([event_mgt_id])
  @@index([date])
  @@index([recordedBy], map: "event_attendance_summary_recordedBy_fkey")
}

model event_attendance {
  id         Int       @id @default(autoincrement())
  event_id   Int
  user_id    Int
  created_at DateTime  @default(now())
  event      event_mgt @relation(fields: [event_id], references: [id])
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id], map: "event_attendance_event_id_fkey")
  @@index([user_id], map: "event_attendance_user_id_fkey")
}

model event_biometric_punch {
  id                Int       @id @default(autoincrement())
  event_mgt_id      Int
  device_id         Int?
  device_ip         String
  device_port       String?
  device_user_id    String
  device_user_name  String?
  matched_user_id   Int?
  matched_member_id String?
  matched_user_name String?
  record_time       DateTime
  state             Int       @default(-1)
  raw_payload       Json
  imported_by       Int
  imported_by_name  String
  imported_at       DateTime  @default(now())
  event             event_mgt @relation(fields: [event_mgt_id], references: [id])
  matched_user      user?     @relation("event_biometric_punch_matched_user", fields: [matched_user_id], references: [id])
  imported_by_user  user      @relation("event_biometric_punch_imported_by_user", fields: [imported_by], references: [id])

  @@unique([event_mgt_id, device_ip, device_user_id, record_time, state], map: "event_biometric_punch_event_device_user_time_state_key")
  @@index([event_mgt_id, record_time], map: "event_biometric_punch_event_time_idx")
  @@index([matched_user_id, record_time], map: "event_biometric_punch_matched_user_time_idx")
  @@index([imported_by, imported_at], map: "event_biometric_punch_imported_by_time_idx")
}

model event_biometric_import_job {
  id                  Int                           @id @default(autoincrement())
  event_mgt_id        Int
  occurrence_date     DateTime
  dry_run             Boolean                       @default(false)
  status              biometric_import_job_status   @default(QUEUED)
  progress_percentage Int                           @default(0)
  current_step        String?
  progress_payload    Json?
  request_payload     Json
  result_payload      Json?
  error_message       String?                       @db.Text
  created_by          Int
  created_by_name     String
  created_at          DateTime                      @default(now())
  started_at          DateTime?
  completed_at        DateTime?
  failed_at           DateTime?
  updated_at          DateTime                      @updatedAt
  event               event_mgt                     @relation(fields: [event_mgt_id], references: [id])
  created_by_user     user                          @relation("event_biometric_import_job_created_by_user", fields: [created_by], references: [id])

  @@index([event_mgt_id, occurrence_date], map: "event_biometric_import_job_event_date_idx")
  @@index([status, created_at], map: "event_biometric_import_job_status_created_idx")
  @@index([created_by, created_at], map: "event_biometric_import_job_created_by_time_idx")
}

model event_registers {
  id                Int       @id @default(autoincrement())
  event_id          Int
  user_id           Int?
  attendee_name     String?
  attendee_email    String?
  attendee_phone    String?
  attendee_location String?
  is_member         Boolean   @default(false)
  member_id         String?
  created_at        DateTime  @default(now())
  event             event_mgt @relation(fields: [event_id], references: [id])
  user              user?     @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@unique([event_id, user_id], map: "event_registers_event_id_user_id_key")
  @@unique([event_id, attendee_email], map: "event_registers_event_id_attendee_email_key")
  @@index([event_id], map: "event_attendance_event_id_fkey")
  @@index([user_id], map: "event_attendance_user_id_fkey")
  @@index([member_id], map: "event_registers_member_id_idx")
}

model request {
  id                      Int                              @id @default(autoincrement())
  request_id              String
  user_id                 Int
  event_id                Int?
  department_id           Int
  request_approval_status RequestApprovalStatus
  requisition_date        DateTime
  currency                String
  user_sign               String?
  updated_by_user_id      Int?
  updated_at              DateTime?
  attachmentsList         request_attachment[]
  department              department                       @relation(fields: [department_id], references: [id])
  event                   event_mgt?                       @relation(fields: [event_id], references: [id])
  user                    user                             @relation(fields: [user_id], references: [id])
  request_approvals       request_approvals?
  request_comments        request_comments[]
  products                requested_item[]                 @relation("ProductRequest")
  approval_instances      requisition_approval_instances[]
  notification_events     requisition_notification_events[]

  @@index([user_id], map: "request_user_id_fkey")
  @@index([department_id], map: "request_department_id_fkey")
  @@index([event_id], map: "request_event_id_fkey")
  @@index([updated_by_user_id], map: "request_updated_by_user_id_idx")
  @@index([request_approval_status], map: "request_approval_status_idx")
}

model event_reports {
  id                   Int                                  @id @default(autoincrement())
  event_id             Int
  event_date           DateTime
  status               EventReportStatus                    @default(DRAFT)
  final_approver_user_id Int?
  final_acted_by_user_id Int?
  final_acted_at       DateTime?
  created_by           Int
  updated_by           Int?
  created_at           DateTime                             @default(now())
  updated_at           DateTime                             @default(now()) @updatedAt
  event                event_mgt                            @relation(fields: [event_id], references: [id], onDelete: Cascade)
  creator              user                                 @relation("event_report_created_by", fields: [created_by], references: [id])
  updater              user?                                @relation("event_report_updated_by", fields: [updated_by], references: [id])
  final_actor          user?                                @relation("event_report_final_acted_by", fields: [final_acted_by_user_id], references: [id])
  department_approvals event_report_department_approvals[]
  attendance_approval  event_report_attendance_approval?
  finance              event_report_finance?
  finance_approvals    event_report_finance_approvals[]
  viewers              event_report_viewers[]
  final_approval_instances event_report_final_approval_instances[]
  notification_events  event_report_notification_events[]

  @@unique([event_id, event_date])
  @@index([event_id])
  @@index([status])
  @@index([final_approver_user_id])
  @@index([created_by])
  @@index([updated_by])
  @@index([final_acted_by_user_id])
}

model event_report_department_approvals {
  id                 Int                              @id @default(autoincrement())
  event_report_id    Int
  department_id      Int
  status             EventReportSectionApprovalStatus @default(PENDING)
  approved_by_user_id Int?
  approved_at        DateTime?
  event_report       event_reports                    @relation(fields: [event_report_id], references: [id], onDelete: Cascade)
  department         department                       @relation(fields: [department_id], references: [id])
  approved_by_user   user?                            @relation("event_report_department_approved_by", fields: [approved_by_user_id], references: [id])

  @@unique([event_report_id, department_id], map: "er_dept_appr_erid_did_uk")
  @@index([department_id])
  @@index([approved_by_user_id])
}

model event_report_attendance_approval {
  id                 Int                              @id @default(autoincrement())
  event_report_id    Int                              @unique
  status             EventReportSectionApprovalStatus @default(PENDING)
  approved_by_user_id Int?
  approved_at        DateTime?
  event_report       event_reports                    @relation(fields: [event_report_id], references: [id], onDelete: Cascade)
  approved_by_user   user?                            @relation("event_report_attendance_approved_by", fields: [approved_by_user_id], references: [id])

  @@index([approved_by_user_id])
}

model event_report_finance {
  id                 Int       @id @default(autoincrement())
  event_report_id    Int       @unique
  income_json        String    @db.LongText
  expense_json       String    @db.LongText
  total_income       Float     @default(0)
  total_expense      Float     @default(0)
  surplus            Float     @default(0)
  updated_by_user_id Int?
  updated_at         DateTime  @default(now()) @updatedAt
  event_report       event_reports @relation(fields: [event_report_id], references: [id], onDelete: Cascade)
  updated_by_user    user?     @relation("event_report_finance_updated_by", fields: [updated_by_user_id], references: [id])

  @@index([updated_by_user_id])
}

model event_report_finance_approvals {
  id                 Int                              @id @default(autoincrement())
  event_report_id    Int
  role               EventReportFinanceRole
  role_owner_user_id Int?
  status             EventReportSectionApprovalStatus @default(PENDING)
  approved_by_user_id Int?
  approved_at        DateTime?
  event_report       event_reports                    @relation(fields: [event_report_id], references: [id], onDelete: Cascade)
  role_owner_user    user?                            @relation("event_report_finance_role_owner", fields: [role_owner_user_id], references: [id])
  approved_by_user   user?                            @relation("event_report_finance_approved_by", fields: [approved_by_user_id], references: [id])

  @@unique([event_report_id, role])
  @@index([role_owner_user_id])
  @@index([approved_by_user_id])
}

